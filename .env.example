## Manual environment for the DuckDB Iceberg REST catalog benchmark.
##
##   cp .env.example .env
##   set -a && source .env && set +a
##   uv run scripts/catalog_benchmark.py --list-targets
##
## On this machine, the normal path is direnv + dotfiles_env instead:
##
##   direnv allow
##   direnv exec . uv run scripts/catalog_benchmark.py --list-targets
##
## The public `.envrc` loads:
##
##   ~/Developer/dotfiles_env/projects/irc-duckdb-bench.envrc
##
## Use `.env` only for local overrides or for running outside that system.
## `.env` is ignored by git.

## Required for any benchmark run. Use a DuckDB CLI with the Iceberg REST write
## options you want to test.
DUCKDB_CLI=/path/to/duckdb
# DUCKDB_BUILD_DIR=/path/to/duckdb/source

## Local Lakekeeper target from docker-compose.yml.
LAKEKEEPER_S3_KEY_ID=minio-root-user
LAKEKEEPER_S3_SECRET=minio-root-password

## Local Apache Polaris quickstart target.
# POLARIS_LOCAL_ID=
# POLARIS_LOCAL_SECRET=
# POLARIS_LOCAL_OAUTH_TOKEN_URI=http://localhost:8181/api/catalog/v1/oauth/tokens

## Remote Polaris-compatible Iceberg REST target.
# POLARIS_URL=
# POLARIS_WAREHOUSE=
# POLARIS_ID=
# POLARIS_SECRET=
# POLARIS_OAUTH_TOKEN_URI=${POLARIS_URL}/v1/oauth/tokens
# POLARIS_OAUTH_SCOPE=PRINCIPAL_ROLE:ALL
# POLARIS_DEFAULT_REGION=us-east-1

## Snowflake Horizon target.
## External-engine writes to Horizon need key-pair auth. A PAT can read but
## createTable 403s. One-time: scripts/configure_horizon_schema.sh.
## Each session: scripts/refresh_horizon_token.sh mints HORIZON_ACCESS_TOKEN from
## the SNOWFLAKE_* key-pair credential.
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_SQL_API_HOST=${SNOWFLAKE_ACCOUNT}.snowflakecomputing.com
# SNOWFLAKE_USER=
# SNOWFLAKE_ROLE=
# SNOWFLAKE_WAREHOUSE=
# SNOWFLAKE_DATABASE=
# SNOWFLAKE_SCHEMA=
# SNOWFLAKE_PRIVATE_KEY=                 ## base64 DER or PEM; signs the Horizon JWT.
# HORIZON_ENDPOINT=https://${SNOWFLAKE_ACCOUNT}.snowflakecomputing.com/polaris/api/catalog
# HORIZON_OAUTH2_SERVER_URI=${HORIZON_ENDPOINT}/v1/oauth/tokens
# HORIZON_OAUTH2_SCOPE=session:role:YOUR_ROLE
# HORIZON_WAREHOUSE=                     ## the Horizon catalog (database) name
# HORIZON_SCHEMA=AWS_CLOUD_COST          ## UPPERCASE: REST namespace is case-sensitive on write.
# HORIZON_ACCESS_TOKEN=                  ## Written by scripts/refresh_horizon_token.sh.
# SNOWFLAKE_EXTERNAL_VOLUME=FUSION_ADAPTERS_CI_TEMP
# SNOWFLAKE_DEFAULT_REGION=us-east-1     ## Must match the external volume region.
