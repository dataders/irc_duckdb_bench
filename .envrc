export IRC_DUCKDB_BENCH_ENV_FILE="${IRC_DUCKDB_BENCH_ENV_FILE:-$HOME/Developer/dotfiles_env/projects/irc-duckdb-bench.envrc}"

if command -v source_dotfiles_env >/dev/null 2>&1; then
  source_dotfiles_env irc-duckdb-bench
fi

source_env_if_exists .env

if [ -n "${DUCKDB_CLI:-}" ]; then
  PATH_add "$(dirname "$DUCKDB_CLI")"
fi
